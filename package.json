{
  "name": "helpnow-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:app": "npm run start --workspace=packages/app",
    "clean": "rm -rf node_modules packages/*/node_modules"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "axios": "^1.13.2",
    "expo": "^54.0.0",
    "expo-router": "~6.0.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "19.1.10",
    "@types/react-native": "0.70.12",
    "turbo": "^1.10.0",
    "typescript": "^5.9.3"
  }
}
