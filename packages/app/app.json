{
  "expo": {
    "name": "HelpNow",
    "slug": "helpnow-solidarity",
    "version": "1.0.0",
    "scheme": "helpnow",
    "userInterfaceStyle": "light",

    "icon": "./assets/images/icon.png",

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.elionay001.helpnowsolidarity"
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font"
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}
